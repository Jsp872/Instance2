# =============================================
# .gitignore — Unity 6 | Rider + Visual Studio
# Basé sur : https://github.com/github/gitignore/blob/main/Unity.gitignore
# =============================================

# --- Dossiers générés par Unity ---
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
.utmp/

# --- Fichiers de log ---
*.log

# --- Captures mémoire (peuvent être très lourdes et sensibles) ---
/[Mm]emoryCaptures/

# --- Enregistrements ---
/[Rr]ecordings/

# =============================================
# JetBrains Rider
# =============================================
/.idea/
/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user

# =============================================
# Visual Studio
# =============================================
.vs/
ExportedObj/
.consulo/

# --- Fichiers solution/projet auto-générés (VS & Rider) ---
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# =============================================
# Fichiers .meta Unity générés
# =============================================
*.pidb.meta
*.pdb.meta
*.mdb.meta

# =============================================
# Builds & packages
# =============================================
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# =============================================
# Blender
# =============================================
*.blend1
*.blend1.meta

# =============================================
# Addressables
# =============================================
/ServerData/
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# =============================================
# Visual Scripting (si utilisé)
# =============================================
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# =============================================
# Divers
# =============================================
sysinfo.txt
mono_crash.*
crashlytics-build.properties
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# --- Asset Store Tools (décommenter si nécessaire) ---
# /[Aa]ssets/AssetStoreTools*

# --- Gradle (Android builds) ---
.gradle/
